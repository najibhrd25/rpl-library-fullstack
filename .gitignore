# Monorepo Ignored Files

# Node modules
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment files
.env
.env*
backend/.env
frontend/.env*

# Next.js build
frontend/.next/
frontend/out/

# Production builds
frontend/build/

# Uploads & Assets
backend/uploads/covers/*
!backend/uploads/covers/.gitkeep
backend/uploads/profiles/*
!backend/uploads/profiles/.gitkeep

# Prisma
backend/src/generated/prisma

# OS files
.DS_Store
Thumb.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Misc
*.pem
.vercel/
frontend/.vercel/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
